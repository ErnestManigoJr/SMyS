PORT=4000

# Your deployed frontend URL — used for CORS
ALLOWED_ORIGINS=http://localhost:5173

# LiveKit — get these from https://cloud.livekit.io
# Leave blank to run in demo mode (no real audio, but app still works)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Your LiveKit Cloud WebSocket URL e.g. wss://your-app.livekit.cloud
LIVEKIT_URL=

# OpenAI — get from https://platform.openai.com/api-keys
# Used for Whisper rephrasing. Leave blank to use the whisper text as-is.
OPENAI_API_KEY=

# Supabase — get from https://supabase.com/dashboard
# Used for clip storage. Leave blank for in-memory demo mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
